<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nfc.attendance.controller.DashboardController">

    <!-- Top Bar -->
    <top>
        <HBox style="-fx-padding: 15; -fx-background-color: #1a1a2e; -fx-spacing: 20;">
            <Label text="NFC Attendance Pro" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-pref-width: 300;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" style="-fx-text-fill: #aaa;"/>
            <Button text="Logout" onAction="#onLogoutClicked" style="-fx-padding: 8 20;"/>
        </HBox>
    </top>

    <!-- Left Navigation -->
    <left>
        <VBox style="-fx-padding: 20; -fx-background-color: #16213e; -fx-spacing: 10; -fx-pref-width: 200;">
            <Button text="Dashboard" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showDashboard"/>
            <Button text="Students" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showStudentManagement"/>
            <Button text="Sessions" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showSessionManagement"/>
            <Button text="Attendance" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showAttendance"/>
            <Button text="Reports" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showReports"/>
            <Separator/>
            <Button text="Settings" style="-fx-padding: 10; -fx-pref-width: 180;" onAction="#showSettings"/>
        </VBox>
    </left>

    <!-- Center Content -->
    <center>
        <StackPane fx:id="contentPane"/>
    </center>
</BorderPane>

