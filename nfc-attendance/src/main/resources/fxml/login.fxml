<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nfc.attendance.controller.LoginController"
      spacing="20" style="-fx-padding: 40; -fx-alignment: center;">

    <HBox alignment="CENTER">
        <Label text="NFC Attendance Pro" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
    </HBox>

    <VBox spacing="10" style="-fx-border-color: #555; -fx-border-radius: 5; -fx-padding: 30; -fx-pref-width: 350;">

        <Label text="Admin Login" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter username" style="-fx-padding: 10;"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Enter password" style="-fx-padding: 10;"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

        <HBox spacing="10">
            <Button text="Login" style="-fx-padding: 10 40; -fx-font-size: 14;" onAction="#onLoginClicked"/>
            <Hyperlink text="Register New Admin" onAction="#onRegisterClicked"/>
        </HBox>
    </VBox>
</VBox>

